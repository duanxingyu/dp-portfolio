{
  "name": "portfolio-showcase",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-portfolio.mjs",
    "dev": "pnpm run sync && concurrently -n server,client -c blue,green \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --env-file=.env.dev --watch server/index.js",
    "build": "pnpm run sync && vite build",
    "build:pages": "pnpm run sync && vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "fastify": "^5.2.1",
    "framer-motion": "^12.42.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
